# Copy to /opt/new-api/.env on the server and edit.
# new-api uses SQLite automatically when SQL_DSN is NOT set.

# Timezone
TZ=Asia/Shanghai

# REQUIRED: random string so login sessions survive restarts.
# Generate with: openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string

# Record upstream error logs (visible in the admin Logs page)
ERROR_LOG_ENABLED=true

# Node name shown in audit logs
NODE_NAME=new-api-hz

# SQLite path is /opt/new-api/one-api.db by default (working dir of the service).
# Uncomment to override:
# SQLITE_PATH=/opt/new-api/one-api.db?_busy_timeout=30000
